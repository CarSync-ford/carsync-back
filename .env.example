# Database (PostgreSQL)
DB_URL=jdbc:postgresql://localhost:5432/mydb
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# Server
SERVER_PORT=8080

# Security
BCRYPT_SALT=10

# CORS
CORS_ALLOWED_ORIGINS=*

# JWT
JWT_SECRET=
JWT_EXPIRATION_MINUTES=
JWT_ISSUER=

# HMAC
HMAC_SECRET=
HMAC_ENABLED=true
