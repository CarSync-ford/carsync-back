# Database - use PostgreSQL connection string in production
DB_URL=jdbc:postgresql://localhost:5432/mydb

# Database credentials (optional - can be embedded in DB_URL)
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# Server
SERVER_PORT=8080

# Security
BCRYPT_SALT=10

# H2 Console (set to false when using PostgreSQL)
H2_CONSOLE_ENABLED=true